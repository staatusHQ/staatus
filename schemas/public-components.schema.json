{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.staatus.dev/public-components.schema.json",
  "title": "Staatus public components API",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "components"],
  "properties": {
    "schemaVersion": { "const": "staatus.public.v1" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "status", "statusLabel", "uptime90d", "timeline"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "group": { "type": "string" },
          "status": { "type": "string" },
          "statusLabel": { "type": "string" },
          "uptime90d": { "type": ["number", "null"] },
          "check": { "type": "object" },
          "links": { "type": "array" },
          "tags": { "type": "array" },
          "history": { "type": "array" },
          "timeline": {
            "type": "array",
            "minItems": 90,
            "maxItems": 90,
            "items": {
              "type": "object",
              "required": ["date", "status", "statusLabel", "uptime"],
              "properties": {
                "date": { "type": "string", "format": "date" },
                "status": {
                  "type": "string",
                  "enum": ["operational", "degraded", "partial_outage", "major_outage", "maintenance", "unknown"]
                },
                "statusLabel": { "type": "string" },
                "uptime": { "type": ["number", "null"] },
                "incidents": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["id", "title", "status", "impact"],
                    "properties": {
                      "id": { "type": "string" },
                      "title": { "type": "string" },
                      "status": { "type": "string" },
                      "impact": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
